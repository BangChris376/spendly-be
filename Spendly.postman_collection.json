    {
      "name": "🔍 Scan Receipt (OCR)",
      "item": [
        {
          "name": "Upload Struk",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/scans/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "receipt",
                  "type": "file",
                  "src": "",
                  "description": "File gambar struk (JPG/PNG/PDF, max 5MB)"
                }
              ]
            }
          }
        },
        {
          "name": "Get Scan Result (polling)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/scans/:id",
            "variable": [{ "key": "id", "value": "uuid-scan" }],
            "description": "Poll tiap 2 detik sampai status = 'completed' atau 'failed'"
          }
        },
        {
          "name": "Confirm Scan → Simpan Transaksi",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/scans/:id/confirm",
            "variable": [{ "key": "id", "value": "uuid-scan" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant_name\": \"Indomaret\",\n  \"total_amount\": 88000,\n  \"category_id\": \"uuid-kategori\",\n  \"wallet_id\": \"uuid-wallet\",\n  \"date\": \"2026-05-14\",\n  \"notes\": \"Scan dari struk\"\n}"
            }
          }
        },
        {
          "name": "Get Scan History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/scans"
          }
