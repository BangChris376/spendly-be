{
  "info": {
    "name": "Spendly API",
    "description": "REST API for Spendly Financial Tracker. Base URL: http://localhost:3000/api/v1\n\nQuick start:\n1. Edit the `base_url` collection variable if your server runs elsewhere.\n2. Run Auth > Login. The access token and refresh token are saved automatically.\n3. Run Wallets > Create Wallet and Categories > Get All Categories to populate the `wallet_id` and `category_id` variables, then any other request will work.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:3000/api/v1", "type": "string" },
    { "key": "token",          "value": "",                              "type": "string" },
    { "key": "refresh_token",  "value": "",                              "type": "string" },
    { "key": "reset_token",    "value": "",                              "type": "string" },
    { "key": "transaction_id", "value": "",                              "type": "string" },
    { "key": "wallet_id",      "value": "",                              "type": "string" },
    { "key": "category_id",    "value": "",                              "type": "string" },
    { "key": "budget_id",      "value": "",                              "type": "string" },
    { "key": "scan_id",        "value": "",                              "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Server Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "http://localhost:3000/health"
          }
        }
      ]
    },

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 201) {",
            "  const data = pm.response.json().data;",
            "  pm.collectionVariables.set('token', data.accessToken);",
            "  pm.collectionVariables.set('refresh_token', data.refreshToken);",
            "}"
          ]}}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"first_name\": \"Budi\",\n  \"last_name\": \"Santoso\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  const data = pm.response.json().data;",
            "  pm.collectionVariables.set('token', data.accessToken);",
            "  pm.collectionVariables.set('refresh_token', data.refreshToken);",
            "}"
          ]}}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex.graham@spendly.io\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  const data = pm.response.json().data;",
            "  pm.collectionVariables.set('token', data.accessToken);",
            "  pm.collectionVariables.set('refresh_token', data.refreshToken);",
            "}"
          ]}}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  const data = pm.response.json().data;",
            "  if (data && data.reset_token) pm.collectionVariables.set('reset_token', data.reset_token);",
            "}"
          ]}}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex.graham@spendly.io\"\n}"
            },
            "description": "Returns a reset token only when NODE_ENV=development."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"new_password\": \"newpassword123\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Alex\",\n  \"last_name\": \"Graham\",\n  \"monthly_limit\": 25000000\n}"
            }
          }
        },
        {
          "name": "Update Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/me/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"password123\",\n  \"new_password\": \"newpassword456\"\n}"
            }
          }
        },
        {
          "name": "Update Preferences",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/me/preferences",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"push_notifications\": true,\n  \"email_summaries\": false,\n  \"security_alerts\": true,\n  \"spending_alerts\": true,\n  \"dark_mode\": false,\n  \"currency\": \"IDR\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions?page=1&limit=10&type=expense&sort=date&order=DESC",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page",        "value": "1" },
                { "key": "limit",       "value": "10" },
                { "key": "type",        "value": "expense", "description": "income | expense | transfer" },
                { "key": "sort",        "value": "date",    "description": "date | amount | created_at" },
                { "key": "order",       "value": "DESC",    "description": "ASC | DESC" },
                { "key": "date_from",   "value": "",        "disabled": true },
                { "key": "date_to",     "value": "",        "disabled": true },
                { "key": "category_id", "value": "{{category_id}}", "disabled": true },
                { "key": "wallet_id",   "value": "{{wallet_id}}",   "disabled": true },
                { "key": "search",      "value": "",        "disabled": true },
                { "key": "amount_min",  "value": "",        "disabled": true },
                { "key": "amount_max",  "value": "",        "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions/{{transaction_id}}",
              "host": ["{{base_url}}"],
              "path": ["transactions", "{{transaction_id}}"]
            }
          }
        },
        {
          "name": "Create Transaction (Expense)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('transaction_id', pm.response.json().data.id);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/transactions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"expense\",\n  \"amount\": 85000,\n  \"merchant_name\": \"Indomaret\",\n  \"category_id\": \"{{category_id}}\",\n  \"wallet_id\": \"{{wallet_id}}\",\n  \"date\": \"2026-05-14\",\n  \"notes\": \"Daily groceries\"\n}"
            }
          }
        },
        {
          "name": "Create Transaction (Income)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/transactions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"income\",\n  \"amount\": 15000000,\n  \"merchant_name\": \"Salary Deposit\",\n  \"category_id\": \"{{category_id}}\",\n  \"wallet_id\": \"{{wallet_id}}\",\n  \"date\": \"2026-05-14\"\n}"
            }
          }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/transactions/{{transaction_id}}",
              "host": ["{{base_url}}"],
              "path": ["transactions", "{{transaction_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 90000,\n  \"notes\": \"Updated note\"\n}"
            }
          }
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/transactions/{{transaction_id}}",
              "host": ["{{base_url}}"],
              "path": ["transactions", "{{transaction_id}}"]
            }
          }
        },
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions/summary?period=month",
              "host": ["{{base_url}}"],
              "path": ["transactions", "summary"],
              "query": [
                { "key": "period", "value": "month", "description": "month | year" },
                { "key": "year",   "value": "2026",  "disabled": true },
                { "key": "month",  "value": "5",     "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Cash Flow",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions/cash-flow?months=6",
              "host": ["{{base_url}}"],
              "path": ["transactions", "cash-flow"],
              "query": [{ "key": "months", "value": "6" }]
            }
          }
        },
        {
          "name": "Get Spending By Day",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/transactions/spending-by-day"
          }
        },
        {
          "name": "Export Transactions to CSV",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/transactions/export-csv"
          }
        }
      ]
    },

