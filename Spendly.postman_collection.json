          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/scans/:id",
            "variable": [{ "key": "id", "value": "uuid-scan" }]
          }
        }
