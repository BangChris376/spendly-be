            "description": "Home page payload: balance summary, recent transactions, budget tracking, 7-month wealth growth."
          }
        },
        {
          "name": "Insights",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/analysis/insights",
            "description": "Analysis page payload: 6-month cash flow, weekday heatmap, AI category clusters, recurring merchants, LSTM forecast, rule-based insights."
          }
        },
        {
          "name": "Spending Forecast",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/analysis/forecast",
            "description": "Next-week spending prediction across the 8 AI categories. Returns 503 when the AI service is unavailable."
          }
