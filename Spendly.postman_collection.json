    {
      "name": "Scans",
      "item": [
        {
          "name": "Upload Receipt",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 202) {",
            "  pm.collectionVariables.set('scan_id', pm.response.json().data.scan_id);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/scans/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "receipt",
                  "type": "file",
                  "src": "",
                  "description": "JPG, PNG or PDF, max 5MB"
                }
              ]
            },
            "description": "Returns 202 with scan_id and status=processing. Poll Get Scan Result until status is completed or failed."
          }
        },
        {
          "name": "Get Scan Result",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/scans/{{scan_id}}",
              "host": ["{{base_url}}"],
              "path": ["scans", "{{scan_id}}"]
            }
          }
        },
        {
          "name": "Confirm Scan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/scans/{{scan_id}}/confirm",
              "host": ["{{base_url}}"],
              "path": ["scans", "{{scan_id}}", "confirm"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant_name\": \"Indomaret\",\n  \"total_amount\": 88000,\n  \"category_id\": \"{{category_id}}\",\n  \"wallet_id\": \"{{wallet_id}}\",\n  \"date\": \"2026-05-14\",\n  \"notes\": \"From receipt scan\"\n}"
            },
            "description": "Saves the scan result as a transaction. All fields are optional and fall back to AI suggestions."
          }
        },
        {
          "name": "List Scan History",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/scans"
          }
        },
        {
          "name": "Delete Scan",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/scans/{{scan_id}}",
              "host": ["{{base_url}}"],
              "path": ["scans", "{{scan_id}}"]
            }
          }
        }
      ]
    },

    {
      "name": "Analysis",
      "item": [
        {
          "name": "Dashboard Overview",
          "request": {
            "method": "GET",
