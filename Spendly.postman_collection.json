{
  "info": {
    "name": "Spendly API",
    "description": "REST API untuk Spendly Financial Tracker\nBase URL: http://localhost:3000/api/v1\n\nCara pakai:\n1. Set variable 'base_url' dan 'token'\n2. Jalankan Register atau Login dulu\n3. Token otomatis tersimpan di variable 'token'",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000/api/v1", "type": "string" },
    { "key": "token",    "value": "",                             "type": "string" },
    { "key": "refresh_token", "value": "",                        "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  const d = pm.response.json().data;",
            "  pm.collectionVariables.set('token', d.accessToken);",
            "  pm.collectionVariables.set('refresh_token', d.refreshToken);",
            "  pm.test('Register berhasil', () => pm.expect(d.accessToken).to.be.a('string'));",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"first_name\": \"Budi\",\n  \"last_name\": \"Santoso\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const d = pm.response.json().data;",
            "  pm.collectionVariables.set('token', d.accessToken);",
            "  pm.collectionVariables.set('refresh_token', d.refreshToken);",
            "  pm.test('Login berhasil', () => pm.expect(d.accessToken).to.be.a('string'));",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex.graham@spendly.io\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/auth/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Alex\",\n  \"last_name\": \"Graham\",\n  \"monthly_limit\": 25000000\n}"
            }
          }
        },
        {
          "name": "Update Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/auth/me/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"password123\",\n  \"new_password\": \"newpassword456\"\n}"
            }
          }
        },
        {
          "name": "Update Preferences",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/auth/me/preferences",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"push_notifications\": true,\n  \"email_summaries\": false,\n  \"security_alerts\": true,\n  \"spending_alerts\": true,\n  \"dark_mode\": false,\n  \"currency\": \"IDR\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "💸 Transactions",
      "item": [
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/transactions?page=1&limit=10&type=expense&sort=date&order=DESC",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page",     "value": "1"       },
                { "key": "limit",    "value": "10"      },
                { "key": "type",     "value": "expense", "description": "income | expense | transfer" },
                { "key": "sort",     "value": "date"    },
                { "key": "order",    "value": "DESC"    },
                { "key": "date_from","value": "",        "disabled": true },
                { "key": "date_to",  "value": "",        "disabled": true },
                { "key": "category_id", "value": "",    "disabled": true },
                { "key": "search",   "value": "",        "disabled": true },
                { "key": "amount_min","value": "",       "disabled": true },
                { "key": "amount_max","value": "",       "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/transactions/:id",
            "variable": [{ "key": "id", "value": "uuid-transaksi-disini" }]
          }
        },
        {
          "name": "Create Transaction (Expense)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/transactions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"expense\",\n  \"amount\": 85000,\n  \"merchant_name\": \"Indomaret\",\n  \"category_id\": \"uuid-kategori\",\n  \"wallet_id\": \"uuid-wallet\",\n  \"date\": \"2026-05-14\",\n  \"notes\": \"Belanja harian\"\n}"
            }
          }
        },
        {
          "name": "Create Transaction (Income)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/transactions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"income\",\n  \"amount\": 15000000,\n  \"merchant_name\": \"Salary Deposit\",\n  \"category_id\": \"uuid-kategori-income\",\n  \"wallet_id\": \"uuid-wallet\",\n  \"date\": \"2026-05-14\"\n}"
            }
          }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/transactions/:id",
            "variable": [{ "key": "id", "value": "uuid-transaksi" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 90000,\n  \"notes\": \"Update catatan\"\n}"
            }
          }
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/transactions/:id",
            "variable": [{ "key": "id", "value": "uuid-transaksi" }]
          }
        },
        {
          "name": "Get Summary (bulan ini)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/transactions/summary?period=month",
              "host": ["{{base_url}}"],
              "path": ["transactions","summary"],
              "query": [
                { "key": "period", "value": "month", "description": "month | year" },
                { "key": "year",   "value": "2026",  "disabled": true },
                { "key": "month",  "value": "5",     "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Cash Flow (6 bulan)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/transactions/cash-flow?months=6"
          }
        },
        {
          "name": "Get Spending By Day",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/transactions/spending-by-day"
          }
        }
      ]
    },

