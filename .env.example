# ─── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spendly_db
DB_USER=postgres
DB_PASSWORD=your_password

# ─── JWT ────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── File Upload ────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ─── CORS (React frontend) ──────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ─── AI Service (FastAPI Tim AI — port 8000) ────────────────────
# Jalankan: uvicorn main:app --reload --port 8000
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT_MS=30000

# ─── Catatan Endpoint FastAPI yang Diharapkan ───────────────────
# POST /ocr            → input: file (gambar struk), output: { text, confidence }
# POST /classify       → input: text + file,         output: { category, confidence, probabilities }
# POST /scan           → input: file (gabungan),     output: { merchant_name, total_amount, date, category, confidence, raw_text }
# POST /forecast       → input: { history: [...] },  output: { forecast: {Beauty,F&B,...}, total_predicted }
# GET  /health         → output: { status: "ok" }
